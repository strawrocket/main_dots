[flavor]
dark = "catppuccin-macchiato"
light = "catppuccin-macchiato"

# Enhanced status bar and borders
[status]
separator_open = ""
separator_close = ""
separator_style = "angly"

[manager]
# Better selection colors
cwd = { fg = "#8aadf4", bold = true }

# Highlighted current item
hovered = { fg = "#cad3f5", bg = "#494d64", bold = true }
preview_hovered = { underline = true }

# Selected items
selected = { fg = "#a6da95", bg = "#363a4f" }

# File count
count_selected = { fg = "#a6da95", bg = "#363a4f", bold = true }
count_copied = { fg = "#eed49f", bg = "#363a4f", bold = true }
count_cut = { fg = "#ed8796", bg = "#363a4f", bold = true }

# Borders
border_symbol = "│"
border_style = { fg = "#5b6078" }

[mode]
normal = { fg = "#8aadf4", bg = "#363a4f", bold = true }
select = { fg = "#a6da95", bg = "#363a4f", bold = true }
unset = { fg = "#f5a97f", bg = "#363a4f", bold = true }

[input]
border = { fg = "#8aadf4" }
title = { fg = "#8aadf4", bold = true }
value = { fg = "#cad3f5" }
selected = { bg = "#494d64" }

[select]
border = { fg = "#8aadf4" }
active = { fg = "#f5bde6", bold = true }
inactive = { fg = "#939ab7" }

[completion]
border = { fg = "#8aadf4" }
active = { fg = "#cad3f5", bg = "#494d64" }
inactive = { fg = "#939ab7" }

# File type colors
[filetype]
rules = [
	# Directories
	{ name = "*/", fg = "#8aadf4", bold = true },
	
	# Media
	{ mime = "image/*", fg = "#f5bde6" },
	{ mime = "video/*", fg = "#f5a97f" },
	{ mime = "audio/*", fg = "#b7bdf8" },
	
	# Documents
	{ mime = "application/pdf", fg = "#ed8796" },
	{ name = "*.md", fg = "#eed49f" },
	{ name = "*.txt", fg = "#cad3f5" },
	
	# Archives
	{ mime = "application/*zip", fg = "#c6a0f6" },
	{ mime = "application/*tar", fg = "#c6a0f6" },
	{ mime = "application/*compressed", fg = "#c6a0f6" },
	
	# Code
	{ name = "*.rs", fg = "#f5a97f" },
	{ name = "*.py", fg = "#8aadf4" },
	{ name = "*.js", fg = "#eed49f" },
	{ name = "*.ts", fg = "#8aadf4" },
	{ name = "*.lua", fg = "#8aadf4" },
	{ name = "*.sh", fg = "#a6da95" },
	{ name = "*.go", fg = "#7dc4e4" },
	{ name = "*.c", fg = "#8aadf4" },
	{ name = "*.cpp", fg = "#f5bde6" },
	{ name = "*.java", fg = "#ed8796" },
	
	# Config
	{ name = "*.toml", fg = "#939ab7" },
	{ name = "*.yaml", fg = "#939ab7" },
	{ name = "*.yml", fg = "#939ab7" },
	{ name = "*.json", fg = "#eed49f" },
	{ name = "*.xml", fg = "#f5a97f" },
	
	# Links
	{ name = "*", is = "link", fg = "#f5bde6", italic = true },
	{ name = "*", is = "orphan", fg = "#ed8796", italic = true },
	
	# Executables
	{ name = "*", is = "exec", fg = "#a6da95", bold = true },
	
	# Hidden
	{ name = ".*", fg = "#6e738d" },
]

[icon]
prepend_space = true
append_space = true
